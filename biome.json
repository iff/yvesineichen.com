{
  "files": {
    "includes": [
      "**",
      "!**/.direnv",
      "!**/.next",
      "!**/node_modules",
      "!**/fonts",
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  }
}
